{
  "name": "git-diff-status-bar",
  "displayName": "Git Diff Status Bar 🟩🟥",
  "description": "Status bar shows coloured count of lines added or removed since last commit. Also includes warnings and terminal command shortcuts. Made for Cursor.",
  "version": "0.0.13",
  "publisher": "vvmike",
  "categories": [
    "Other"
  ],
  "keywords": [
    "git",
    "diff",
    "diff count",
    "statusbar",
    "productivity",
    "line count",
    "lines changed",
    "cursor"
  ],
  "icon": "assets/icon.png",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "main": "./out/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/vvmike/git-diff-status-bar.git"
  },
  "license": "MIT",
  "contributes": {},
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "release": "npm run compile && npm version patch && git push --follow-tags"
  },
  "devDependencies": {
    "@types/node": "^18.15.11",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.0.4"
  }
}
