{
  "name": "git-diff-status-bar",
  "displayName": "Git Diff Status Bar 🟩🟥",
  "description": "Status bar shows coloured count of lines added or removed since last commit. Also includes warnings and terminal command shortcuts. Made for Cursor.",
  "version": "0.0.4",
  "publisher": "vvmike",
  "engines": {
    "vscode": "^1.80.0"
  },
  "main": "./out/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/vvmike/git-diff-status-bar.git"
  },
  "license": "MIT",
  "contributes": {},
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^18.15.11",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.0.4"
  }
}
